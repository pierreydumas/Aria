{
  "name": "aria-performance",
  "version": "1.0.0",
  "description": "Log and query Aria's performance reviews and self-assessments.",
  "author": "Aria Team",
  "layer": 4,
  "dependencies": [
    "api_client"
  ],
  "focus_affinity": [
    "orchestrator"
  ],
  "tools": [
    {
      "name": "log_review",
      "description": "Log a performance review or self-assessment entry.",
      "parameters": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string",
            "description": "Review period (daily, weekly, monthly)"
          },
          "successes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of successes"
          },
          "failures": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of failures"
          },
          "improvements": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Areas for improvement"
          }
        },
        "required": [
          "period",
          "successes",
          "failures",
          "improvements"
        ]
      }
    },
    {
      "name": "get_reviews",
      "description": "Get performance review history.",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "description": "Maximum entries to return (default: 10)"
          }
        }
      }
    },
    {
      "name": "get_improvement_summary",
      "description": "Get performance statistics, trends, and improvement summary.",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_metrics",
      "description": "Get current performance metrics.",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  ],
  "run": "python3 /app/skills/run_skill.py performance {{tool}} '{{args_json}}'"
}
