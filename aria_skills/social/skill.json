{
  "name": "aria-social",
  "version": "1.0.0",
  "description": "Manage Aria's social presence and posts on Moltbook and other platforms.",
  "author": "Aria Team",
  "layer": 3,
  "dependencies": ["api_client", "moltbook"],
  "focus_affinity": ["social", "creative", "journalist"],
  "tools": [
    {
      "name": "social_post",
      "description": "Create a social media post.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "Post content text"
          },
          "platform": {
            "type": "string",
            "enum": ["moltbook", "telegram", "mastodon"],
            "description": "Target platform"
          },
          "mood": {
            "type": "string",
            "description": "Mood/emotion tag"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Hashtags or topics"
          },
          "visibility": {
            "type": "string",
            "enum": ["public", "private", "followers"],
            "description": "Post visibility"
          },
          "simulate": {
            "type": "boolean",
            "description": "Run in safe simulation mode (recommended default true)",
            "default": true
          },
          "chat_id": {
            "type": "string",
            "description": "Optional target Telegram chat id for telegram platform"
          },
          "reply_to": {
            "type": "string",
            "description": "Optional post ID to reply to (creates a comment/reply)"
          }
        },
        "required": ["content", "platform"]
      }
    },
    {
      "name": "social_list",
      "description": "Get recent social posts.",
      "parameters": {
        "type": "object",
        "properties": {
          "platform": {
            "type": "string",
            "description": "Filter by platform"
          },
          "limit": {
            "type": "integer",
            "description": "Maximum posts (default: 20)"
          }
        }
      }
    },
    {
      "name": "social_schedule",
      "description": "Schedule a post for later.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "Post content"
          },
          "platform": {
            "type": "string",
            "description": "Target platform"
          },
          "simulate": {
            "type": "boolean",
            "description": "Store as simulation-only schedule intent",
            "default": true
          },
          "scheduled_for": {
            "type": "string",
            "description": "ISO timestamp for posting"
          }
        },
        "required": ["content", "platform", "scheduled_for"]
      }
    },
    {
      "name": "source_add",
      "description": "Add or update a website source for research recall. Upserts by URL.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Full URL of the website (e.g. https://docs.python.org)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable name (e.g. Python Docs)"
          },
          "category": {
            "type": "string",
            "description": "Category (e.g. ML Framework, Hardware/AI, System, Documentation)"
          },
          "rating": {
            "type": "string",
            "enum": ["preferred", "caution", "avoid"],
            "description": "Source reliability rating"
          },
          "reason": {
            "type": "string",
            "description": "Why this source is preferred/avoided"
          },
          "alternative": {
            "type": "string",
            "description": "Alternative source if this one is rated caution/avoid"
          },
          "last_used": {
            "type": "string",
            "description": "ISO timestamp of last use"
          }
        },
        "required": ["url", "name"]
      }
    },
    {
      "name": "source_list",
      "description": "List website sources with optional filters by category, rating, or search query.",
      "parameters": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "description": "Filter by category"
          },
          "rating": {
            "type": "string",
            "enum": ["preferred", "caution", "avoid"],
            "description": "Filter by rating"
          },
          "q": {
            "type": "string",
            "description": "Search name, URL, or reason"
          },
          "limit": {
            "type": "integer",
            "description": "Maximum results (default: 50)"
          }
        }
      }
    },
    {
      "name": "source_remove",
      "description": "Remove a website source by ID.",
      "parameters": {
        "type": "object",
        "properties": {
          "source_id": {
            "type": "string",
            "description": "UUID of the source to remove"
          }
        },
        "required": ["source_id"]
      }
    },
    {
      "name": "source_stats",
      "description": "Get website source statistics grouped by rating and category.",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  ],
  "run": "python3 /app/skills/run_skill.py social {{tool}} '{{args_json}}'"
}
