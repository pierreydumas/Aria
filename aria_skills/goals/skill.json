{
  "name": "aria-goals",
  "version": "1.0.0",
  "description": "Manage user goals, habits, and progress tracking. Create, update, and query goals with reminders and milestones.",
  "author": "Aria Team",
  "layer": 3,
  "dependencies": [
    "api_client"
  ],
  "focus_affinity": [
    "orchestrator"
  ],
  "tools": [
    {
      "name": "list_goals",
      "description": "List all active goals with their status and progress.",
      "parameters": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "active",
              "in_progress",
              "completed",
              "paused",
              "on_hold",
              "backlog",
              "todo",
              "doing",
              "done",
              "archived",
              "archive",
              "all"
            ],
            "description": "Filter by goal status (default: active)"
          },
          "priority": {
            "type": "integer",
            "description": "Filter by priority level (1-5)"
          },
          "tag": {
            "type": "string",
            "description": "Filter by tag"
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of goals to return (default: 20)"
          }
        }
      }
    },
    {
      "name": "create_goal",
      "description": "Create a new goal with priority and optional deadline.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Goal title"
          },
          "description": {
            "type": "string",
            "description": "Detailed description"
          },
          "priority": {
            "type": "integer",
            "description": "Priority 1-5 (1 is highest)"
          },
          "due_date": {
            "type": "string",
            "description": "Optional deadline in ISO format"
          },
          "parent_id": {
            "type": "string",
            "description": "Optional parent goal ID for subtasks"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional categorization tags"
          }
        },
        "required": [
          "title"
        ]
      }
    },
    {
      "name": "update_goal",
      "description": "Update progress or details on a goal.",
      "parameters": {
        "type": "object",
        "properties": {
          "goal_id": {
            "type": "integer",
            "description": "Goal ID"
          },
          "status": {
            "type": "string",
            "description": "New status for the goal"
          },
          "progress": {
            "type": "integer",
            "description": "Progress percentage (0-100)"
          },
          "priority": {
            "type": "integer",
            "description": "Priority level (1-5)"
          },
          "notes": {
            "type": "string",
            "description": "Progress notes"
          }
        },
        "required": [
          "goal_id"
        ]
      }
    },
    {
      "name": "get_goal",
      "description": "Get details of a specific goal.",
      "parameters": {
        "type": "object",
        "properties": {
          "goal_id": {
            "type": "integer",
            "description": "Goal ID"
          }
        },
        "required": [
          "goal_id"
        ]
      }
    },
    {
      "name": "get_summary",
      "description": "Get a summary of all goals and their overall progress.",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_next_actions",
      "description": "Get recommended next actions across all active goals.",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "add_subtask",
      "description": "Add a subtask to an existing goal.",
      "parameters": {
        "type": "object",
        "properties": {
          "parent_id": {
            "type": "integer",
            "description": "Parent goal ID"
          },
          "title": {
            "type": "string",
            "description": "Subtask title"
          },
          "description": {
            "type": "string",
            "description": "Subtask description"
          }
        },
        "required": [
          "parent_id",
          "title"
        ]
      }
    },
    {
      "name": "complete_subtask",
      "description": "Mark a subtask as completed.",
      "parameters": {
        "type": "object",
        "properties": {
          "parent_id": {
            "type": "integer",
            "description": "Parent goal ID"
          },
          "subtask_id": {
            "type": "string",
            "description": "Subtask ID to complete"
          }
        },
        "required": [
          "parent_id",
          "subtask_id"
        ]
      }
    }
  ],
  "run": "python3 /app/skills/run_skill.py goals {{tool}} '{{args_json}}'"
}
